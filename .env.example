# Authorize.net — get these from https://account.authorize.net/
# Sandbox: https://sandbox.authorize.net/
AUTHORIZE_NET_ENV=sandbox
AUTHORIZE_NET_API_LOGIN_ID=your_api_login_id
AUTHORIZE_NET_TRANSACTION_KEY=your_transaction_key
NEXT_PUBLIC_AUTHORIZE_NET_CLIENT_KEY=your_public_client_key

# Admin panel password (optional, defaults to kushworld2026)
ADMIN_PASSWORD=kushworld2026

# Session signing + password-reset tokens (required in production — 16+ random chars)
SESSION_SECRET=generate_a_long_random_secret_here

# BTC Postage — shipping labels (https://btcpostage.com/api-documentation)
BTCPOSTAGE_API_KEY=your_api_key
BTCPOSTAGE_API_SECRET=your_api_secret
# BTCPOSTAGE_API_URL=https://bitcoinpostage.info/api/
# BTCPOSTAGE_TEST_MODE=true
# BTCPOSTAGE_LABEL_BASE_URL=https://bitcoinpostage.info

# Optional default ship-from (Grok also rotates through data/ship-from-addresses.json)
SHIP_FROM_NAME=Kush World
SHIP_FROM_ADDRESS=123 Your Street
SHIP_FROM_ADDRESS2=
SHIP_FROM_CITY=Your City
SHIP_FROM_STATE=CA
SHIP_FROM_ZIP=90001
SHIP_FROM_COUNTRY=US
SHIP_FROM_PHONE=+15627724106
# Or inline JSON array: SHIP_FROM_ADDRESSES=[{"id":"addr1","name":"...","street":"...",...}]

# Default package profile for rate quotes
DEFAULT_PACKAGE_TYPE=Parcel
DEFAULT_PACKAGE_WEIGHT_LBS=0
DEFAULT_PACKAGE_WEIGHT_OZ=16
DEFAULT_PACKAGE_HEIGHT_IN=6
DEFAULT_PACKAGE_WIDTH_IN=8
DEFAULT_PACKAGE_DEPTH_IN=4

# Discord — website "Login with Discord" (OAuth2 app credentials, NOT the bot token)
# Developer Portal → your app → OAuth2:
#   Redirect URL: https://kushworld.shop/api/auth/discord/callback
#   (local dev: http://localhost:3000/api/auth/discord/callback)
DISCORD_CLIENT_ID=your_discord_application_client_id
DISCORD_CLIENT_SECRET=your_discord_client_secret
# DISCORD_REDIRECT_URI=https://kushworld.shop/api/auth/discord/callback

# Discord bot — grants Verified role when staff approves ID on site (same token as discord-bot/)
# DISCORD_BOT_TOKEN=
# DISCORD_GUILD_ID=475124246905880596
# DISCORD_VERIFIED_ROLE_ID=optional_if_role_name_is_not_Verified
# DISCORD_INTERNAL_SYNC_SECRET=random_secret_bot_uses_to_call_sync-member_api
# Canonical invite (optional override — default is 48HmtfDgQp in lib/discordInvite.ts)
# NEXT_PUBLIC_DISCORD_INVITE_URL=https://discord.gg/TsDbxrZVwg

# Bitcoin checkout (BTC only)
BTC_WALLET_ADDRESS=32Un3zH14ovKpSyfLWtk6pVex69CmSYVjp
BTC_PAYMENT_EXPIRY_MINUTES=30
BTC_MIN_CONFIRMATIONS=1

# Order confirmation emails via Resend (https://resend.com)
RESEND_API_KEY=re_your_key_here
EMAIL_FROM=orders@kushworld.shop

# Cloudflare Turnstile — bot protection on login/signup/admin (https://dash.cloudflare.com/?to=/:account/turnstile)
NEXT_PUBLIC_TURNSTILE_SITE_KEY=your_turnstile_site_key
TURNSTILE_SECRET_KEY=your_turnstile_secret_key

# SMS verification via Twilio (https://twilio.com)
# US numbers require A2P 10DLC brand + campaign registration in Twilio Console
# or SMS will fail with error 30034 (undelivered).
TWILIO_ACCOUNT_SID=your_twilio_account_sid
TWILIO_AUTH_TOKEN=your_twilio_auth_token
TWILIO_PHONE_NUMBER=+15551234567

# Auto ID photo screening (set one — rejects non-ID uploads on receive)
# Grok / xAI — powers ID screening, support chat, product Q&A, admin assist
# https://console.x.ai/team/default/api-keys
XAI_API_KEY=xai-your_key_here
# XAI_VISION_MODEL=grok-4.20-0309-non-reasoning
# XAI_CHAT_MODEL=grok-4.20-0309-non-reasoning
# OpenAI: https://platform.openai.com/api-keys
# OPENAI_API_KEY=sk-your_key_here
# OPENAI_VISION_MODEL=gpt-4o-mini
# Google Gemini: https://aistudio.google.com/apikey
# GEMINI_API_KEY=your_gemini_key_here
# GEMINI_VISION_MODEL=gemini-2.0-flash