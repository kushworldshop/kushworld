# Authorize.net — get these from https://account.authorize.net/
# Sandbox: https://sandbox.authorize.net/
AUTHORIZE_NET_ENV=sandbox
AUTHORIZE_NET_API_LOGIN_ID=your_api_login_id
AUTHORIZE_NET_TRANSACTION_KEY=your_transaction_key
NEXT_PUBLIC_AUTHORIZE_NET_CLIENT_KEY=your_public_client_key

# Admin panel password (optional, defaults to kushworld2026)
ADMIN_PASSWORD=kushworld2026