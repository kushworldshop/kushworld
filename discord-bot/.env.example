# 1. Reset your bot token in Discord Developer Portal (never paste tokens in chat)
# 2. Copy this file to .env and fill in values
# 3. Invite bot: OAuth2 URL Generator → scopes: bot, applications.commands
#    permissions: Manage Channels, Manage Roles, Send Messages, Manage Messages, Read Message History
# 4. Run: npm install && npm run setup

DISCORD_BOT_TOKEN=your_bot_token_here
DISCORD_GUILD_ID=your_server_id_here